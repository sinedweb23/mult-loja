# Obtenha a SERVICE_ROLE_KEY no Dashboard do Supabase: Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Chave de API para autenticação na importação de dados
IMPORTACAO_API_KEY=your_importacao_api_key
# URL base da aplicação (para importação interna e callbacks do gateway)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gateway Rede (e.Rede) – Basic Auth (PV + Token). Mesmo padrão do RedePayment PHP.
# Doc: docs/GATEWAY_PAGAMENTO_REDE.md | https://developer.userede.com.br/e-rede
# EREDE_ENV=sandbox | production (se não definir, dev usa sandbox e deploy usa production)

# -------- SANDBOX --------
EREDE_PV=
EREDE_TOKEN=
EREDE_URL_SANDBOX=https://sandbox-erede.useredecloud.com.br/v1/transactions

# -------- PRODUÇÃO --------
# EREDE_PV_PRODUCTION=
# EREDE_TOKEN_PRODUCTION=
EREDE_URL_PRODUCTION=https://api.userede.com.br/erede/v1/transactions

# Webhook PIX: configurar na Rede a URL https://<seu-dominio>.vercel.app/api/webhook/pix
REDE_WEBHOOK_URL=
# Token do webhook (POST /api/webhook/pix). Header: Authorization: Bearer <token>
REDE_WEBHOOK_TOKEN=
# Exigir token no webhook? Use false para aceitar chamadas sem token (ex.: Rede não envia token)
# REDE_WEBHOOK_REQUIRE_TOKEN=false
# Se der 403 (CloudFront): tente REDE_HEADERS_MINIMAL=true (headers iguais ao PHP/cURL)
# REDE_HEADERS_MINIMAL=true
# User-Agent enviado nas requisições (padrão: curl/7.64.1). Só usado se REDE_HEADERS_MINIMAL não estiver true.
# REDE_USER_AGENT=curl/7.64.1
# Log para suporte: REDE_LOG_HEADERS=true e copie do console "[Rede – log para suporte]"
# REDE_LOG_HEADERS=true
