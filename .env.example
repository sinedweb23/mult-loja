# ============================================================
# Variáveis de ambiente – .env.local (local) = mesmas no Vercel
# ============================================================
#
# VERCEL: Settings → Environment Variables → adicione as mesmas variáveis (Production/Preview).
# SUPABASE: Authentication → URL Configuration:
#   Site URL = mesmo valor de NEXT_PUBLIC_APP_URL (ex: https://eatsimple.com.br)
#   Redirect URLs = adicione: https://eatsimple.com.br/auth/callback
#
# ============================================================

# ---------- Supabase (obrigatório) ----------
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ---------- App / Auth ----------
# URL base do app em produção: use UMA única origem (ex: https://app.seudominio.com).
# Evite alternar www/sem www ou http/https para prevenir erro "PKCE code verifier not found".
# Usado em OAuth (Google) e links de recuperação/primeiro acesso.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Dashboard (Auth): configure para a mesma origem:
# - Site URL = valor de NEXT_PUBLIC_APP_URL (ex: https://app.seudominio.com)
# - Redirect URLs = exatamente: https://app.seudominio.com/auth/callback (e outras rotas exatas se precisar)

# ---------- Importação (API) ----------
# Chave para a rota de importação; altere em produção
IMPORTACAO_API_KEY=sua-chave-secreta

# ---------- Rede (e.Rede – pagamentos) ----------
# Ambiente: sandbox ou production
EREDE_ENV=production

# Sandbox
EREDE_PV_SANDBOX=
EREDE_TOKEN_SANDBOX=
EREDE_URL_SANDBOX=https://sandbox-erede.useredecloud.com.br/v1/transactions

# Produção
EREDE_PV_PRODUCTION=
EREDE_TOKEN_PRODUCTION=
EREDE_URL_PRODUCTION=https://api.userede.com.br/erede/v1/transactions

# Webhook PIX (token para validar o webhook)
REDE_WEBHOOK_TOKEN=

# Opcional: log de headers nas requisições Rede
# REDE_LOG_HEADERS=true

# ---------- Twilio (WhatsApp – aviso de saldo baixo) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número Twilio no formato whatsapp:+5511999999999
TWILIO_WHATSAPP_NUMBER=whatsapp:+5511999999999
# Chave para chamar a rota POST /api/aviso-saldo-whatsapp (header Authorization: Bearer <chave> ou x-api-key)
AVISO_SALDO_WHATSAPP_API_KEY=

# ---------- Google Calendar (Kit Festa – validação de horários) ----------
# ID do calendário (ex.: primary ou email do calendário)
GOOGLE_CALENDAR_ID=

# Credenciais: use UMA das opções abaixo:
# Opção 1 – Caminho do arquivo JSON (recomendado; ex.: credencials/loja-eat-81b87bafe0b8.json)
# GOOGLE_APPLICATION_CREDENTIALS=credencials/loja-eat-81b87bafe0b8.json
# Opção 2 – Conteúdo do JSON em uma linha (obtenha em Google Cloud → Contas de serviço → Criar chave JSON)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
